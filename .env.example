# Backend environment configuration.
# Copy this file to .env and fill in real values: cp .env.example .env
# .env is gitignored and must never be committed.
#
# Frontend (React) variables live separately in frontend/.env.example.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Shared secret required in the X-API-Key header on every /api/* request.
# The server refuses to start if this is unset.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Comma-separated list of origins allowed to call the API via CORS.
# No wildcards — list each frontend origin explicitly. The server refuses to
# start if this is unset.
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional (sensible defaults shown)
# ---------------------------------------------------------------------------

# Fallback user identifier when a request doesn't supply a ?user= value.
DEFAULT_USER=unknown_user

# Absolute or relative path to the weapon-detection model (used by demo.py).
WEAPON_MODEL_PATH=backend/models/weapon_detect.pt

# Hugging Face inference token. If empty, the chat falls back to local logic.
HF_API_TOKEN=

# Port the API server listens on.
PORT=5000
