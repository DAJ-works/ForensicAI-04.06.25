# Frontend (React) environment configuration.
# Copy this file to frontend/.env and fill in values.
# Create React App only exposes variables prefixed with REACT_APP_,
# and they are baked in at build time (not read at runtime).

# Base URL of the backend API.
REACT_APP_API_URL=http://localhost:5000

# API key sent in the X-API-Key header on every API request.
# Must match the backend's API_KEY (in the root .env).
REACT_APP_API_KEY=

# Identifier for the current user, sent with API requests and shown in the UI.
REACT_APP_CURRENT_USER=unknown_user
